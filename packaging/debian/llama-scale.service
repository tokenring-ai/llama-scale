[Unit]
Description=llama-scale OpenAI-compatible LLM router
Documentation=https://github.com/tokenring-ai/llama-scale
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=llama-scale
Group=llama-scale
ExecStart=/usr/bin/llama-scale --config /etc/llama-scale/config.yaml
EnvironmentFile=-/etc/default/llama-scale
Restart=on-failure
RestartSec=5
NoNewPrivileges=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/var/log/llama-scale
PrivateTmp=true

[Install]
WantedBy=multi-user.target